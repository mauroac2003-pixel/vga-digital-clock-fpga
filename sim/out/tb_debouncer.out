    %pop/vec4 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5dbd57ea1610_0, 0, 1;
    %vpi_call 2 40 "$display", "[%0t] Reset liberado. signal_clean inicial = %b", $time, v0x5dbd57ea16b0_0 {0 0 0};
    %vpi_call 2 43 "$display", "[%0t] Test 1: Pulso corto de 10 ciclos (rebote)", $time {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5dbd57ea1750_0, 0, 1;
