    .scope S_0x5dbd57e838f0;
T_3 ;
    %vpi_call 2 34 "$display", "=== TEST: debouncer ===" {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5dbd57ea1610_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5dbd57ea1750_0, 0, 1;
    %pushi/vec4 5, 0, 32;
T_3.0 %dup/vec4;
    %pushi/vec4 0, 0, 32;
    %cmp/s;
    %jmp/1xz T_3.1, 5;
    %jmp/1 T_3.1, 4;
    %pushi/vec4 1, 0, 32;
    %sub;
