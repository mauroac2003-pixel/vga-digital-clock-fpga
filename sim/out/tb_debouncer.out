T_3.7 ;
    %vpi_call 2 55 "$display", "[%0t] Test 2: Se\303\261al estable durante 0xFFFF+10 ciclos", $time {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5dbd57ea1750_0, 0, 1;
    %pushi/vec4 65545, 0, 32;
T_3.8 %dup/vec4;
    %pushi/vec4 0, 0, 32;
    %cmp/u;
    %jmp/1 T_3.9, 4;
    %pushi/vec4 1, 0, 32;
