    %cmpi/e 0, 0, 1;
    %jmp/0xz  T_3.14, 6;
    %vpi_call 2 70 "$display", "PASS: Bajada de se\303\261al propagada correctamente" {0 0 0};
    %jmp T_3.15;
T_3.14 ;
    %vpi_call 2 72 "$display", "FAIL: Bajada no propagada" {0 0 0};
T_3.15 ;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5dbd57ea1750_0, 0, 1;
    %pushi/vec4 100, 0, 32;
T_3.16 %dup/vec4;
    %pushi/vec4 0, 0, 32;
    %cmp/s;
    %jmp/1xz T_3.17, 5;
    %jmp/1 T_3.17, 4;
