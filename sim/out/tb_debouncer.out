T_3.11 ;
    %vpi_call 2 65 "$display", "[%0t] Test 3: Bajar se\303\261al estable", $time {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5dbd57ea1750_0, 0, 1;
    %pushi/vec4 65545, 0, 32;
T_3.12 %dup/vec4;
    %pushi/vec4 0, 0, 32;
    %cmp/u;
    %jmp/1 T_3.13, 4;
    %pushi/vec4 1, 0, 32;
