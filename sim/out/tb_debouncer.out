    .thread T_1;
    .scope S_0x5dbd57e838f0;
T_2 ;
    %delay 5000, 0;
    %load/vec4 v0x5dbd57e766e0_0;
    %inv;
    %store/vec4 v0x5dbd57e766e0_0, 0, 1;
    %jmp T_2;
