:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/v2005_math.vpi";
:vpi_module "/usr/lib/x86_64-linux-gnu/ivl/va_math.vpi";
S_0x5c09a4c74170 .scope module, "tb_clk_25MHz" "tb_clk_25MHz" 2 10;
 .timescale -9 -12;
v0x5c09a4c8f520_0 .var "clk", 0 0;
v0x5c09a4c8f5c0_0 .net "clk_25_en", 0 0, v0x5c09a4c62590_0;  1 drivers
v0x5c09a4c8f660_0 .var/i "cycle", 31 0;
v0x5c09a4c8f700_0 .var/i "last_pulse_cycle", 31 0;
v0x5c09a4c8f7c0_0 .var/i "pulses", 31 0;
v0x5c09a4c8f8f0_0 .var "rst", 0 0;
v0x5c09a4c8f990_0 .var/i "spacing", 31 0;
E_0x5c09a4c3a6c0 .event posedge, v0x5c09a4c60fc0_0;
S_0x5c09a4c74320 .scope module, "uut" "clk_25MHz" 2 20, 3 22 0, S_0x5c09a4c74170;
 .timescale -9 -12;
    .port_info 0 /INPUT 1 "clk";
    .port_info 1 /INPUT 1 "rst";
    .port_info 2 /OUTPUT 1 "clk_25_en";
v0x5c09a4c60fc0_0 .net "clk", 0 0, v0x5c09a4c8f520_0;  1 drivers
v0x5c09a4c62590_0 .var "clk_25_en", 0 0;
v0x5c09a4c63cb0_0 .var "cnt", 1 0;
v0x5c09a4c8f3e0_0 .net "rst", 0 0, v0x5c09a4c8f8f0_0;  1 drivers
E_0x5c09a4c39e20 .event posedge, v0x5c09a4c8f3e0_0, v0x5c09a4c60fc0_0;
    .scope S_0x5c09a4c74320;
T_0 ;
    %wait E_0x5c09a4c39e20;
    %load/vec4 v0x5c09a4c8f3e0_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_0.0, 8;
    %pushi/vec4 0, 0, 2;
    %assign/vec4 v0x5c09a4c63cb0_0, 0;
    %pushi/vec4 0, 0, 1;
    %assign/vec4 v0x5c09a4c62590_0, 0;
    %jmp T_0.1;
T_0.0 ;
    %load/vec4 v0x5c09a4c63cb0_0;
    %cmpi/e 3, 0, 2;
    %jmp/0xz  T_0.2, 4;
    %pushi/vec4 0, 0, 2;
    %assign/vec4 v0x5c09a4c63cb0_0, 0;
    %pushi/vec4 1, 0, 1;
    %assign/vec4 v0x5c09a4c62590_0, 0;
    %jmp T_0.3;
T_0.2 ;
    %load/vec4 v0x5c09a4c63cb0_0;
    %addi 1, 0, 2;
    %assign/vec4 v0x5c09a4c63cb0_0, 0;
    %pushi/vec4 0, 0, 1;
    %assign/vec4 v0x5c09a4c62590_0, 0;
T_0.3 ;
T_0.1 ;
    %jmp T_0;
    .thread T_0;
    .scope S_0x5c09a4c74170;
T_1 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c09a4c8f520_0, 0, 1;
    %end;
    .thread T_1;
    .scope S_0x5c09a4c74170;
T_2 ;
    %delay 5000, 0;
    %load/vec4 v0x5c09a4c8f520_0;
    %inv;
    %store/vec4 v0x5c09a4c8f520_0, 0, 1;
    %jmp T_2;
    .thread T_2;
    .scope S_0x5c09a4c74170;
T_3 ;
    %vpi_call 2 38 "$display", "=== TEST: clk_25MHz ===" {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c09a4c8f8f0_0, 0, 1;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5c09a4c8f7c0_0, 0, 32;
    %pushi/vec4 5, 0, 32;
T_3.0 %dup/vec4;
    %pushi/vec4 0, 0, 32;
    %cmp/s;
    %jmp/1xz T_3.1, 5;
    %jmp/1 T_3.1, 4;
    %pushi/vec4 1, 0, 32;
    %sub;
    %wait E_0x5c09a4c3a6c0;
    %jmp T_3.0;
T_3.1 ;
    %pop/vec4 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5c09a4c8f8f0_0, 0, 1;
    %vpi_call 2 44 "$display", "[%0t] Reset liberado", $time {0 0 0};
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5c09a4c8f700_0, 0, 32;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5c09a4c8f660_0, 0, 32;
    %pushi/vec4 40, 0, 32;
T_3.2 %dup/vec4;
    %pushi/vec4 0, 0, 32;
    %cmp/s;
    %jmp/1xz T_3.3, 5;
    %jmp/1 T_3.3, 4;
    %pushi/vec4 1, 0, 32;
    %sub;
    %wait E_0x5c09a4c3a6c0;
    %load/vec4 v0x5c09a4c8f660_0;
    %addi 1, 0, 32;
    %store/vec4 v0x5c09a4c8f660_0, 0, 32;
    %load/vec4 v0x5c09a4c8f5c0_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_3.4, 8;
    %load/vec4 v0x5c09a4c8f7c0_0;
    %addi 1, 0, 32;
    %store/vec4 v0x5c09a4c8f7c0_0, 0, 32;
    %load/vec4 v0x5c09a4c8f660_0;
    %load/vec4 v0x5c09a4c8f700_0;
    %sub;
    %store/vec4 v0x5c09a4c8f990_0, 0, 32;
    %load/vec4 v0x5c09a4c8f7c0_0;
    %cmpi/s 1, 0, 32;
    %flag_or 5, 4; GT is !LE
    %flag_inv 5;
    %jmp/0xz  T_3.6, 5;
    %load/vec4 v0x5c09a4c8f990_0;
    %cmpi/e 4, 0, 32;
    %jmp/0xz  T_3.8, 4;
    %vpi_call 2 58 "$display", "PASS: Pulso %0d cada 4 ciclos (ciclo %0d)", v0x5c09a4c8f7c0_0, v0x5c09a4c8f660_0 {0 0 0};
    %jmp T_3.9;
T_3.8 ;
    %vpi_call 2 60 "$display", "FAIL: Pulso %0d en ciclo %0d, espaciado=%0d (esperado 4)", v0x5c09a4c8f7c0_0, v0x5c09a4c8f660_0, v0x5c09a4c8f990_0 {0 0 0};
T_3.9 ;
T_3.6 ;
    %load/vec4 v0x5c09a4c8f660_0;
    %store/vec4 v0x5c09a4c8f700_0, 0, 32;
T_3.4 ;
    %jmp T_3.2;
T_3.3 ;
    %pop/vec4 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5c09a4c8f8f0_0, 0, 1;
    %wait E_0x5c09a4c3a6c0;
    %wait E_0x5c09a4c3a6c0;
    %load/vec4 v0x5c09a4c8f5c0_0;
    %cmpi/e 0, 0, 1;
    %jmp/0xz  T_3.10, 6;
    %vpi_call 2 71 "$display", "PASS: Reset pone clk_25_en en 0" {0 0 0};
    %jmp T_3.11;
T_3.10 ;
    %vpi_call 2 73 "$display", "FAIL: clk_25_en deber\303\255a ser 0 tras reset" {0 0 0};
T_3.11 ;
    %vpi_call 2 75 "$display", "Total pulsos detectados en 40 ciclos: %0d (esperado ~9)", v0x5c09a4c8f7c0_0 {0 0 0};
    %vpi_call 2 76 "$display", "=== FIN TEST: clk_25MHz ===" {0 0 0};
    %vpi_call 2 77 "$finish" {0 0 0};
    %end;
    .thread T_3;
