    %load/vec4 v0x5f00500e2d60_0;
    %cmpi/e 4095, 0, 12;
    %jmp/0xz  T_6.2, 6;
    %vpi_call 2 74 "$display", "PASS: Lectura addr=0 \342\206\222 data=0xFFF" {0 0 0};
