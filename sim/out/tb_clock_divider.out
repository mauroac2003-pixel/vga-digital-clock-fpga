v0x5d304895dcf0_0 .var/real "last_rise_time", 0 0;
v0x5d304895de00_0 .var/real "period_ns", 0 0;
v0x5d304895dec0_0 .var "rst", 0 0;
E_0x5d3048945320 .event posedge, v0x5d30489335e0_0;
E_0x5d304890cfd0 .event posedge, v0x5d3048933900_0;
E_0x5d30489478d0 .event posedge, v0x5d304895dec0_0, v0x5d30489335e0_0;
    .scope S_0x5d304890c490;
T_0 ;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5d30489335e0_0, 0, 1;
    %end;
    .thread T_0;
    .scope S_0x5d304890c490;
T_1 ;
    %delay 5000, 0;
    %load/vec4 v0x5d30489335e0_0;
    %inv;
    %store/vec4 v0x5d30489335e0_0, 0, 1;
    %jmp T_1;
    .thread T_1;
    .scope S_0x5d304890c490;
T_2 ;
    %wait E_0x5d30489478d0;
    %load/vec4 v0x5d304895dec0_0;
    %flag_set/vec4 8;
    %jmp/0xz  T_2.0, 8;
    %pushi/vec4 0, 0, 5;
    %assign/vec4 v0x5d304895dc10_0, 0;
    %pushi/vec4 0, 0, 1;
    %assign/vec4 v0x5d3048935a80_0, 0;
    %jmp T_2.1;
T_2.0 ;
    %load/vec4 v0x5d304895dc10_0;
    %pad/u 32;
    %cmpi/e 4, 0, 32;
    %jmp/0xz  T_2.2, 4;
    %load/vec4 v0x5d3048935a80_0;
    %inv;
    %assign/vec4 v0x5d3048935a80_0, 0;
    %pushi/vec4 0, 0, 5;
    %assign/vec4 v0x5d304895dc10_0, 0;
    %jmp T_2.3;
T_2.2 ;
    %load/vec4 v0x5d304895dc10_0;
    %addi 1, 0, 5;
    %assign/vec4 v0x5d304895dc10_0, 0;
T_2.3 ;
T_2.1 ;
    %jmp T_2;
    .thread T_2;
    .scope S_0x5d304890c490;
T_3 ;
    %vpi_call 2 36 "$display", "=== TEST: clock_divider ===" {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5d304895dec0_0, 0, 1;
    %pushi/vec4 5, 0, 32;
T_3.0 %dup/vec4;
    %pushi/vec4 0, 0, 32;
    %cmp/s;
    %jmp/1xz T_3.1, 5;
    %jmp/1 T_3.1, 4;
    %pushi/vec4 1, 0, 32;
    %sub;
    %wait E_0x5d3048945320;
    %jmp T_3.0;
T_3.1 ;
    %pop/vec4 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v0x5d304895dec0_0, 0, 1;
    %wait E_0x5d304890cfd0;
    %vpi_func 2 42 "$time" 64 {0 0 0};
    %cvt/rv;
    %store/real v0x5d304895dcf0_0;
    %wait E_0x5d304890cfd0;
    %vpi_func 2 45 "$time" 64 {0 0 0};
    %cvt/rv;
    %load/real v0x5d304895dcf0_0;
    %sub/wr;
    %store/real v0x5d304895de00_0;
    %vpi_call 2 46 "$display", "[%0t] Periodo medido: %0.0f ns", $time, v0x5d304895de00_0 {0 0 0};
    %load/real v0x5d304895de00_0;
    %pushi/real 1677721600, 4072; load=100.000
    %cmp/wr;
    %flag_get/vec4 4;
    %flag_set/vec4 8;
    %jmp/0xz  T_3.2, 8;
    %vpi_call 2 49 "$display", "PASS: Periodo de clk_1hz correcto" {0 0 0};
    %jmp T_3.3;
T_3.2 ;
    %vpi_call 2 51 "$display", "FAIL: Periodo incorrecto. Obtenido=%0.0f ns", v0x5d304895de00_0 {0 0 0};
T_3.3 ;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v0x5d304895dec0_0, 0, 1;
    %wait E_0x5d3048945320;
    %wait E_0x5d3048945320;
    %load/vec4 v0x5d3048933900_0;
    %cmpi/e 0, 0, 1;
    %jmp/0xz  T_3.4, 6;
    %vpi_call 2 56 "$display", "PASS: Reset pone clk_1hz en 0" {0 0 0};
    %jmp T_3.5;
T_3.4 ;
    %vpi_call 2 58 "$display", "FAIL: clk_1hz deberia ser 0 tras reset" {0 0 0};
T_3.5 ;
    %vpi_call 2 60 "$display", "=== FIN TEST: clock_divider ===" {0 0 0};
    %vpi_call 2 61 "$finish" {0 0 0};
    %end;
    .thread T_3;
